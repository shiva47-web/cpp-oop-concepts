#include <iostream>
using namespace std;

// Abstract base class
class Shape {
public:
    // Pure virtual function
    virtual void draw() = 0;

    // Normal function
    void message() {
        cout << "This is Shape class" << endl;
    }
};

// Derived class 1
class Circle : public Shape {
public:
    void draw() override {
        cout << "Drawing Circle" << endl;
    }
};

// Derived class 2
class Rectangle : public Shape {
public:
    void draw() override {
        cout << "Drawing Rectangle" << endl;
    }
};

int main() {
    Shape* s;   // Base class pointer

    Circle c;
    Rectangle r;

    s = &c;
    s->draw();   // Calls Circle's draw()

    s = &r;
    s->draw();   // Calls Rectangle's draw()

    return 0;
}
